<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="null" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="93ca092a-11f6-4b59-befc-71e89e3410e0">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idprmhnn" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
     permohonan.`idprmhnn` AS permohonan_idprmhnn,
     permohonan.`tggl` AS permohonan_tggl,
     permohonan.`jns` AS permohonan_jns,
     permohonan.`idpmhn` AS permohonan_idpmhn,
     permohonan.`nmpmhn` AS permohonan_nmpmhn,
     permohonan.`alm` AS permohonan_alm,
     permohonan.`notelp` AS permohonan_notelp,
     permohonan.`idtnh` AS permohonan_idtnh,
     permohonan.`lks` AS permohonan_lks,
     permohonan.`vlm` AS permohonan_vlm,
     permohonan.`haktanah` AS permohonan_haktanah,
     pemohon.`idpmhn` AS pemohon_idpmhn,
     pemohon.`nmpmhn` AS pemohon_nmpmhn,
     pemohon.`nik` AS pemohon_nik,
     pemohon.`alm` AS pemohon_alm,
     pemohon.`notlp` AS pemohon_notlp,
     tanah.`idtnh` AS tanah_idtnh,
     tanah.`lks` AS tanah_lks,
     tanah.`vlm` AS tanah_vlm,
     tanah.`stts` AS tanah_stts,
     tanah.`haktanah` AS tanah_haktanah
FROM
     `pemohon` pemohon INNER JOIN `permohonan` permohonan ON pemohon.`idpmhn` = permohonan.`idpmhn`
     INNER JOIN `tanah` tanah ON permohonan.`idtnh` = tanah.`idtnh`
where permohonan.idprmhnn=$P{idprmhnn}]]>
	</queryString>
