	<property name="ireport.y" value="0"/>
	<parameter name="idpngsn" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
     penugasan.`idpngsn` AS penugasan_idpngsn,
     penugasan.`idprmhnn` AS penugasan_idprmhnn,
     penugasan.`nmpmhn` AS penugasan_nmpmhn,
     penugasan.`notelp` AS penugasan_notelp,
     penugasan.`alm` AS penugasan_alm,
     penugasan.`jns` AS penugasan_jns,
     penugasan.`vlm` AS penugasan_vlm,
     penugasan.`lks` AS penugasan_lks,
     penugasan.`haktanah` AS penugasan_haktanah,
     penugasan.`idjdwl` AS penugasan_idjdwl,
     penugasan.`tggl` AS penugasan_tggl,
     penugasan.`idptgs` AS penugasan_idptgs,
     penugasan.`nmptgs` AS penugasan_nmptgs,
     penugasan.`nip` AS penugasan_nip,
     penugasan.`notlp` AS penugasan_notlp,
     permohonan.`idprmhnn` AS permohonan_idprmhnn,
     permohonan.`tggl` AS permohonan_tggl,
     permohonan.`jns` AS permohonan_jns,
     permohonan.`idpmhn` AS permohonan_idpmhn,
     permohonan.`nmpmhn` AS permohonan_nmpmhn,
     permohonan.`alm` AS permohonan_alm,
     permohonan.`notelp` AS permohonan_notelp,
     permohonan.`idtnh` AS permohonan_idtnh,
     permohonan.`lks` AS permohonan_lks,
     permohonan.`vlm` AS permohonan_vlm,
     permohonan.`haktanah` AS permohonan_haktanah,
     jadwal.`idjdwl` AS jadwal_idjdwl,
     jadwal.`tggl` AS jadwal_tggl,
     tugas.`idptgs` AS tugas_idptgs,
     tugas.`nmptgs` AS tugas_nmptgs,
     tugas.`nip` AS tugas_nip,
     tugas.`notlp` AS tugas_notlp
FROM
     `permohonan` permohonan INNER JOIN `penugasan` penugasan ON permohonan.`idprmhnn` = penugasan.`idprmhnn`
     INNER JOIN `jadwal` jadwal ON penugasan.`idjdwl` = jadwal.`idjdwl`
     INNER JOIN `tugas` tugas ON penugasan.`idptgs` = tugas.`idptgs`
where 
penugasan.idpngsn = $P{idpngsn}]]>
	</queryString>
